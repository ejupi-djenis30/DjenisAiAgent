# Copy to .env. Never commit the populated file.

# Required by every runtime
GEMINI_API_KEY=""
DJENIS_GEMINI_MODEL="gemini-3.5-flash"

# Safe-by-default capability policy: observe | interact | system
DJENIS_PERMISSION_TIER="observe"
DJENIS_ALLOWED_PATHS="."
DJENIS_ALLOWED_APPLICATIONS=""
DJENIS_ALLOWED_SHELL_COMMANDS=""

# System-tier tools require this second, explicit opt-in. Leave disabled unless
# you understand that shell, file-write, app-launch, and screenshot-save tools
# can change or disclose data on the machine.
DJENIS_CONFIRM_DANGEROUS_ACTIONS="false"

# Required only for --web. Generate a unique value of at least 24 characters,
# for example: python -c "import secrets; print(secrets.token_urlsafe(32))"
DJENIS_WEB_AUTH_TOKEN=""
DJENIS_WEB_HOST="127.0.0.1"
DJENIS_WEB_ALLOWED_ORIGINS=""
DJENIS_WEB_SESSION_TTL="3600"
DJENIS_WEB_RATE_LIMIT_PER_MINUTE="60"
DJENIS_WEB_LOGIN_RATE_LIMIT_PER_MINUTE="10"
DJENIS_WEB_UPLOAD_MAX_BYTES="5242880"
DJENIS_WEB_SESSION_COOKIE_SECURE="false"

# Runtime and browser connection
DJENIS_RUNTIME_MODE="auto"
DJENIS_BROWSER_DEBUGGING_HOST="127.0.0.1"
DJENIS_BROWSER_DEBUGGING_PORT="9222"
# SELENIUM_REMOTE_URL="http://localhost:4444/wd/hub"

# Agent limits
DJENIS_MAX_LOOP_TURNS="50"
DJENIS_MAX_MOUSE_POSITIONING_ATTEMPTS="10"
DJENIS_ACTION_TIMEOUT="45"
DJENIS_API_TIMEOUT="120"
DJENIS_API_MAX_RETRIES="3"
DJENIS_API_RETRY_DELAY="2.0"
DJENIS_TASK_TIMEOUT="900"
DJENIS_TEMPERATURE="0.2"
DJENIS_MAX_TOKENS="4096"

# Logging and capture
DJENIS_LOG_LEVEL="INFO"
DJENIS_VERBOSE_LOGGING="false"
DJENIS_ENABLE_AUDIT_LOG="true"
DJENIS_AUDIT_LOG_PATH="logs/agent-audit.jsonl"
DJENIS_STREAM_MAX_FPS="15"
DJENIS_STREAM_FRAME_QUALITY="80"
DJENIS_PERCEPTION_DOWNSCALE="1.0"

# Optional local transcription
DJENIS_LOCAL_TRANSCRIPTION="false"
DJENIS_VOSK_MODEL_PATH=""
